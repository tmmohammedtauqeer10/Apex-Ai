# =============================================================================
# Apex AI Chatbox - .gitignore
# =============================================================================
# This file prevents unwanted files from being tracked in the Apex AI Chatbox
# GitHub repository. Keep this repo clean and secure.
# =============================================================================

# --------------------------------------
# macOS
# --------------------------------------
.DS_Store
.AppleDouble
.LSOverride
._*
.Spotlight-V100
.Trashes

# --------------------------------------
# Windows
# --------------------------------------
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/

# --------------------------------------
# Linux
# --------------------------------------
*~
.nfs*

# --------------------------------------
# IDEs & Editors
# --------------------------------------
.vscode/
.idea/
*.swp
*.swo
*.swn
*.bak
*.tmp
*.temp

# --------------------------------------
# Environment & Secrets (Apex AI Chatbox)
# --------------------------------------
.env
.env.local
.env.*.local
*.pem
*.key
secrets/
config/secrets.yml

# --------------------------------------
# Docker (Apex AI Chatbox)
# --------------------------------------
*.log
docker-compose.override.yml

# --------------------------------------
# Ollama / LLM Model Files
# Do NOT commit large AI model binaries to Apex AI Chatbox repo
# --------------------------------------
models/
*.gguf
*.bin
*.safetensors
*.onnx
*.pt
*.pth
*.ckpt

# --------------------------------------
# Python (if scripts added to Apex AI Chatbox)
# --------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
env/
venv/
.venv/
pip-log.txt

# --------------------------------------
# Node.js (if frontend added to Apex AI Chatbox)
# --------------------------------------
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
dist/
build/

# --------------------------------------
# Database & Data (Apex AI Chatbox)
# --------------------------------------
*.db
*.sqlite
*.sqlite3
data/
chat-history/

# --------------------------------------
# Misc
# --------------------------------------
*.zip
*.tar.gz
*.rar
